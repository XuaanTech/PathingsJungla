---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const { title, description, image, url, type } = Astro.props;
const siteTitle = title || "Pathings Jungla | League of Legends";
const siteDescription = description || "Guías de jungla, full clears, builds, runas y conceptos avanzados para League of Legends.";
const siteImage = image || "https://pathingsjungla.pages.dev/img/og-image.jpg";
const siteUrl = url || "https://pathingsjungla.pages.dev/";
const siteType = type || "website";
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Título y descripción -->
  <title>{siteTitle}</title>
  <meta name="description" content={siteDescription} />
  <meta name="robots" content="index, follow" />
  <meta name="keywords" content="League of Legends, jungla, pathings, guías, full clear, builds, runas, macro, campeones, LoL" />
  <meta name="author" content="Pathings Jungla" />

  <!-- Canonical -->
  <link rel="canonical" href={siteUrl} />

  <!-- Color de tema para navegadores móviles -->
  <meta name="theme-color" content="#060D17" />

  <!-- Open Graph mejorado -->
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={siteDescription} />
  <meta property="og:image" content={siteImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:type" content={siteType} />
  <meta property="og:site_name" content="Pathings Jungla" />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter Cards mejoradas -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={siteDescription} />
  <meta name="twitter:image" content={siteImage} />
  <meta name="twitter:image:alt" content="Pathings Jungla - Guías de jungla LoL" />
  <meta name="twitter:site" content="@PathingsJungla" />

  <!-- Iconos del sitio (favicon, Apple, Android) -->
  <link rel="icon" href="/favicon.ico?v=6" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=6" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=6" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=6" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Configuración para aplicaciones web progresivas (opcional) -->
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Pathings Jungla" />

  <!-- Datos estructurados globales (WebSite) -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Pathings Jungla",
      "url": "https://pathingsjungla.pages.dev",
      "description": "Guías de jungla para League of Legends",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://pathingsjungla.pages.dev/?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  </script>
</head>
<body>
  <slot />
  <!-- Aquí no se incluyen scripts ni CSS globales, cada página los suyos -->
</body>
</html>