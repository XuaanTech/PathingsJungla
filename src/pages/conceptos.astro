---
import Layout from '../layouts/Layout.astro';
import conceptos from '../data/conceptos.json';

const pageTitle = "Conceptos de Jungla | Pathings Jungla";
const pageDescription = "Todos los conceptos avanzados para mejorar tu macro en la jungla de League of Legends.";
const pageUrl = "https://pathingsjungla.pages.dev/conceptos/";
const pageImage = "https://pathingsjungla.pages.dev/img/og-image.jpg"; // o una imagen específica
---

<Layout
  title={pageTitle}
  description={pageDescription}
  url={pageUrl}
  image={pageImage}
  type="website"
>
  <main>
    <h1>Conceptos de Jungla</h1>
    <div class="concept-grid">
      {conceptos.map((concepto) => (
        <article class="concept-card" data-id={concepto.id}>
          <a href={`/conceptos/${concepto.id}`}>
            <h3>{concepto.name}</h3>
            <p>{concepto.shortDesc}</p>
          </a>
        </article>
      ))}
    </div>
    <a href="/">← Volver al inicio</a>
  </main>

  <!-- CSS específico de esta página -->
  <link rel="stylesheet" href="/styles/conceptos.css" />
  <!-- JS específico (si lo necesitas en el futuro) -->
  <!-- <script src="/scripts/conceptos.js" defer></script> -->
</Layout>