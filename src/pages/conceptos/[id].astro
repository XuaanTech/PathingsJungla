---
import Layout from '../../layouts/Layout.astro';
import conceptos from '../../data/conceptos.json';

export function getStaticPaths() {
  return conceptos.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;

// Título de la página
const pageTitle = `${item.name} - Conceptos de Jungla | Pathings Jungla`;

// Descripción para el meta (limpia de HTML y truncada)
const rawText = item.description || item.shortDesc;           // texto original con HTML
const plainText = rawText.replace(/<[^>]*>/g, '').trim();     // eliminamos etiquetas
const pageDescription = plainText.length > 150
  ? plainText.substring(0, 147) + '...'
  : plainText;

// Imagen para Open Graph (usa el icono si no es ruta relativa)
const pageImage = item.icon && !item.icon.startsWith('../')
  ? item.icon.trim().replace(/^\.\.\//, '/')
  : "https://pathingsjungla.pages.dev/img/og-image.jpg";

const pageUrl = `https://pathingsjungla.pages.dev/conceptos/${item.id}`;
const pageType = "article";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  url={pageUrl}
  type={pageType}
>
  <!-- ================= HEADER ================= -->
  <header class="concepto-header">
    <div class="header-content">
      <a href="/" class="back-button">← Volver al inicio</a>
      <!-- Icono (solo si existe) -->
      {item.icon && <img id="concepto-icon" class="concepto-header-icon" src={item.icon.trim().startsWith('../') ? item.icon.trim().replace(/^\.\.\//, '/') : item.icon.trim()} alt={item.name} style="display:block" />}
      <div class="concepto-info">
        <h1 id="concepto-name">{item.name}</h1>
        <span id="concepto-short" class="concepto-style">{item.shortDesc}</span>
      </div>
    </div>
  </header>

  <!-- ================= MAIN ================= -->
  <main class="guide-container">

    <!-- Video (si existe) -->
    {item.video && (
      <section id="video-section">
        <h2>Vídeo explicativo</h2>
        <iframe id="concepto-video" src={item.video} allowfullscreen></iframe>
      </section>
    )}

    <!-- Explicación detallada -->
    <section>
      <h2>Explicación</h2>
      <div id="concepto-descripcion" set:html={item.description || item.shortDesc} />
    </section>

    <!-- Recursos adicionales (enlaces, etc.) -->
    <section>
      <h2>Recursos adicionales</h2>
      <div id="concepto-recursos">
        <p>Próximamente más guías y ejemplos prácticos.</p>
      </div>
    </section>

  </main>

  <!-- ================= FOOTER ================= -->
  <footer>
    <div class="footer-content">
      <p>© 2025 Pathings Jungla</p>
      <p style="font-size: 0.8rem; color: #888; margin-top: 5px;">
        <a href="/paginas-legales/politicas.html" style="color: #e2b714; text-decoration: none;">Políticas y Aviso Legal</a>
      </p>
    </div>
  </footer>

  <!-- Estilos propios de esta página -->
  <link rel="stylesheet" href="/styles/conceptos.css" />
  <!-- <script src="/scripts/conceptos.js" defer></script> -->
</Layout>